filters:
  and:
    - file.inFolder("Одежда")
properties:
  note.Физическое СУ:
    displayName: ФСУ
  note.Энерго СУ:
    displayName: ЭСУ
  note.Радиационный СУ:
    displayName: РСУ
  note.Радиационный Иммунитет:
    displayName: Р Имм.
  note.Тип брони:
    displayName: Тип
views:
  - type: table
    name: Table
    filters:
      and:
        - note["Тип брони"] == "Силовая броня"
    groupBy:
      property: Тип брони
      direction: ASC
    order:
      - file.name
      - Тип брони
      - Физическое СУ
      - Энерго СУ
      - Радиационный СУ
      - Радиационный Иммунитет
      - Очки здоровья
      - Защищаемая часть тела
      - Цена
      - Вес
      - Редкость
      - Оригинальное название
    sort:
      - property: file.name
        direction: ASC
      - property: Физическое СУ
        direction: ASC
      - property: Защищаемая часть тела
        direction: ASC
      - property: Тип
        direction: ASC
      - property: Цена
        direction: ASC
    columnSize:
      note.Физическое СУ: 85
      note.Энерго СУ: 84
      note.Радиационный СУ: 52
      note.Радиационный Иммунитет: 101
      note.Защищаемая часть тела: 231
      note.Вес: 88
      note.Цена: 88
      note.Редкость: 67
