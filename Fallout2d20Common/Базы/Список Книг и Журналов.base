filters:
  and:
    - file.folder == "Книги и Журналы"
properties:
  file.name:
    displayName: Название
views:
  - type: table
    name: Table
    order:
      - file.name
      - Перки
      - Вес
      - Цена
      - Редкость
      - Оригинальное название
    sort:
      - property: Перки
        direction: ASC
      - property: Редкость
        direction: ASC
    columnSize:
      file.name: 267
